# Database Configuration
# Note: These are hardcoded in docker-compose.yml (gameapp/gameapp/gamelibrary)
# For production on your server, update docker-compose.yml directly

# Flask Configuration
FLASK_ENV=development
SECRET_KEY=your-secret-key-here-change-in-production

# Optional: Steam API (for Phase 2 ingestion)
# STEAM_API_KEY=your-steam-api-key-here

# Optional: IGDB API (for game master matching)
# IGDB_CLIENT_ID=your-igdb-client-id-here
# IGDB_ACCESS_TOKEN=your-igdb-access-token-here

