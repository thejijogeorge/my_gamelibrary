# Database Configuration
DB_USER=gameapp
DB_PASSWORD=gameapp
DB_NAME=gamelibrary
DB_PORT=5432

# Flask Configuration
FLASK_ENV=development
SECRET_KEY=your-secret-key-here-change-in-production

# Web Server
